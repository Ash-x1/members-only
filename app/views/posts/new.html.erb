<h1>Create you post:</h1><br><br>

<%= form_with model: @post do |form| %>
  <%= form.label :title %>
  <%= form.text_field :title, placeholder: "PLease insert the title of your post here" %><br><br>
  <%= form.label :body, "Post:" %>
  <%= form.text_area :body, size: "70x5" %><br><br>
  <%= form.submit "Submit" %>
<% end %>
